# ===========================================================================
# JCI Beauty — environment template. Copy to `.env` and fill in real values.
# ===========================================================================

# --- Database (PostgreSQL / Supabase) ---------------------------------------
# Use the SESSION POOLER connection string (IPv4) from Supabase → Connect.
# Direct connection (db.<ref>.supabase.co) is IPv6-only on the free tier and
# usually unreachable from shared/VPS hosts. Keep the password symbol-free or
# URL-encode it.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Auth.js (NextAuth v5) — ADMIN/STAFF login only -------------------------
# REQUIRED. Generate a strong, unique secret per environment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET="generate-a-long-random-string"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Email-OTP 2FA at admin login ("true" default; "false" = password-only).
AUTH_2FA_ENABLED="true"

# --- Stripe (test mode) -----------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# --- Email (SMTP / Mailtrap) ------------------------------------------------
# Mailtrap → Sandbox inbox → SMTP Settings → Show Credentials.
MAIL_HOST="sandbox.smtp.mailtrap.io"
MAIL_PORT="2525"
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM="JCI Beauty <no-reply@jcibeauty.com>"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CURRENCY="PHP"
